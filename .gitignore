# =========================
# ha-college-lighting gitignore
# Defines separation between:
# - source code (tracked)
# - generated data (ignored)
# - runtime artifacts (ignored)
# =========================

# =========================
# Python / venv
# =========================
.venv/
venv/

__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# IDE
# =========================
.idea/
.vscode/

# =========================
# Build artifacts (EXE)
# =========================
build/
dist/
*.spec

# =========================
# Data (generated)
# =========================
data/normalized/
data/light_groups/
data/old group/
data/lovelace_cards_generated.txt
data/lovelace_cards_report.json

# =========================
# Local / temporary
# =========================
*.log
*.tmp

# =========================
# Excel (private)
# =========================
data/*.xlsx

# но оставить пример:
!data/example.xlsx

# =========================
# Legacy / мусор
# =========================
scripts/old scripts/
scripts/test_bootstrap.py

launcher/config/
# =========================
# ha-college-lighting gitignore
# Defines separation between:
# - source code (tracked)
# - generated data (ignored)
# - runtime artifacts (ignored)
# =========================

# =========================
# Python / venv
# =========================
.venv/
venv/

__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# IDE
# =========================
.idea/
.vscode/

# =========================
# Build artifacts (EXE)
# =========================
build/
dist/
*.spec

# =========================
# Data (generated)
# =========================
data/normalized/
data/light_groups/
data/old group/
data/lovelace/
data/backups/
data/lovelace_cards_report.json
data/validation_report.json
data/areas/
data/scripts/
data/automations/
data/blueprints/

# =========================
# Handoff для стороннего разработчика (собирается, не версионируется)
# =========================
handoff/
handoff.zip

# =========================
# Секреты (доступ к Home Assistant)
# =========================
.env

# =========================
# Tests
# =========================
.pytest_cache/

# =========================
# Local / temporary
# =========================
*.log
*.tmp

# =========================
# Excel (private)
# =========================
data/*.xlsx

# но оставить примеры (на них держатся тесты):
!data/example.xlsx
!data/object_example.xlsx

# =========================
# Legacy / мусор
# =========================
scripts/old scripts/
scripts/test_bootstrap.py

launcher/config/
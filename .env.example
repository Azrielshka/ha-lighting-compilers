# Доступ к Home Assistant для шага деплоя.
# Скопируйте в .env и заполните. Реальный .env в .gitignore и в git не попадёт.
#
# Токен: Home Assistant -> профиль (внизу слева) -> Long-lived access tokens
#        -> Create token. Нужен токен АДМИНА: иначе Supervisor API не ответит.

HA_BASE_URL=http://192.168.1.50:8123
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
